# Copy this file to .env and fill in your funded Aeneid testnet wallet.
#   cp .env.example .env   (PowerShell: Copy-Item .env.example .env)

# Funded Aeneid testnet wallet private key (no 0x prefix is fine; both work).
# Get testnet IP from the Story faucet, then paste the key here.
WALLET_PRIVATE_KEY=

# Story Aeneid RPC (default works fine).
RPC_URL=https://aeneid.storyrpc.io

# Story-API REST endpoint. Default works on Aeneid but MAY change between
# deployments — if reads/DKG calls start failing, re-check this against the docs.
API_URL=http://172.192.41.96:1317

# A SECOND funded Aeneid testnet wallet that plays the "verifier" in
# 02-disclose / 03-revoke. The verifier sends its own read tx, so this wallet
# must also hold a little testnet IP. Use a throwaway key — this is testnet only.
VERIFIER_PRIVATE_KEY=

# Optional: address of an already-deployed RevocableAllowlistReadCondition.
# Leave blank and `pnpm revoke` will deploy a fresh one from contracts/out/.
# (Run `forge build` in ../contracts first so the artifact exists.)
REVOCABLE_CONDITION_ADDRESS=
