# Copy to .env.local and fill in. Same wallets you used in the Phase 0 harness.
#   Copy-Item .env.example .env.local

# Owner wallet — the CryptId user. Signs allocate/write and owner reads.
WALLET_PRIVATE_KEY=

# Demo verifier wallet — the actor the /verify portal acts as. Must be funded
# (sends its own read tx). Lets one app instance demo both sides of disclosure.
VERIFIER_PRIVATE_KEY=

# Phase 2: deployed condition contract addresses. Leave blank to hide that
# disclosure mode in the UI (it falls back to plain EOA conditions).
# Deploy both with `forge script Deploy` in ../../contracts (prints both),
# or get the revocable one from `pnpm revoke` (root).
REVOCABLE_CONDITION_ADDRESS=
TIMEBOUND_CONDITION_ADDRESS=

# Defaults work on Aeneid; override only if the deployment changes.
RPC_URL=https://aeneid.storyrpc.io
API_URL=http://172.192.41.96:1317
